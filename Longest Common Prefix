class Solution(object):
    def longestCommonPrefix(self, strs):
        """
        :type strs: List[str]
        :rtype: str
        """
        if not strs:
            return "" 
        prefix = ""
        for char in strs[0]:
            for i in range(1, len(strs)):
                if len(strs[i]) <= len(prefix) or strs[i][len(prefix)] != char:
                    return prefix
            prefix += char

        return prefix
